---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hubungan Industri">
  <div class="page-header">
    <h1>Hubungan Industri</h1>
  </div>

  <div class="content">
    <section>
      <h2>Tentang Hubungan Industri</h2>
      <p>Bidang Hubungan Industri (HUBIN) SMKN 1 Rongga berfungsi sebagai jembatan antara sekolah dengan dunia industri dan dunia kerja. Kami berkomitmen untuk memberikan kesempatan praktik kerja industri (PRAKERIN) yang bermutu bagi siswa.</p>
    </section>

    <section>
      <h2>Tujuan Prakerin</h2>
      <ul>
        <li>Memperkuat link and match antara sekolah dengan industri</li>
        <li>Membekali siswa dengan pengalaman kerja nyata</li>
        <li>Meningkatkan kompetensi siswa sesuai standar industri</li>
        <li>Memperluas jaringan kerja sama dengan dunia industri</li>
        <li>Mempermudahkan lulusan dalam mencari pekerjaan</li>
      </ul>
    </section>

    <section>
      <h2>Mitra Industri</h2>
      <p>SMKN 1 Rongga bekerja sama dengan berbagai perusahaan dan industri di antaranya:</p>
      <ul>
        <li>PT. Astra Honda Motor</li>
        <li>PT. Toyota Astra Motor</li>
        <li>PT. Nippon Indosari Corpindo (Roti)</li>
        <li>PT. Charoen Pokphand Indonesia</li>
        <li>PT. Sayurbox</li>
        <li> Berbagai perusahaan dan industri lokal lainnya</li>
      </ul>
    </section>

    <section>
      <h2>Informasi Prakerin</h2>
      <table class="info-table">
        <tr>
          <th>Durasi</th>
          <td>6 bulan (semester Genap)</td>
        </tr>
        <tr>
          <th>Syarat</th>
          <td>Lulus semester 1-3, tidak ada tanggung jawab akademik</td>
        </tr>
        <tr>
          <th>Supervisi</th>
          <td>Guru pembimbing dari sekolah + pembimbing dari industri</td>
        </tr>
        <tr>
          <th>Pelaporan</th>
          <td>Logbook, Laporan, dan Seminar</td>
        </tr>
      </table>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #f97316;
  }

  ul {
    margin-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .info-table {
    width: 100%;
    border-collapse: collapse;
  }

  .info-table th, .info-table td {
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    text-align: left;
  }

  .info-table th {
    background: #f3f4f6;
    width: 200px;
  }
</style>
