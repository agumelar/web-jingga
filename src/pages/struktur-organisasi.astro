---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Struktur Organisasi">
  <div class="page-header">
    <h1>Struktur Organisasi</h1>
  </div>

  <div class="content">
    <section>
      <h2>Struktur Organisasi SMKN 1 Rongga</h2>
      <p>Berikut adalah struktur organisasi SMKN 1 Rongga:</p>

      <div class="org-chart">
        <div class="org-level">
          <div class="org-box top">
            <h3>KEPALA SEKOLAH</h3>
          </div>
        </div>

        <div class="org-level">
          <div class="org-box">
            <h3>WAKASEK</h3>
            <ul>
              <li>Wakasek Kurikulum</li>
              <li>Wakasek Kesiswaan</li>
              <li>Wakasek Hubungan Industri</li>
              <li>Wakasek Sarana Prasarana</li>
            </ul>
          </div>
        </div>

        <div class="org-level">
          <div class="org-box">
            <h3>KETUA PROGRAM KEAHLIAN</h3>
            <ul>
              <li>Ketua ATPH</li>
              <li>Ketua RPL</li>
              <li>Ketua TBSM</li>
            </ul>
          </div>
        </div>

        <div class="org-level">
          <div class="org-box">
            <h3>BAGIAN ADMINISTRASI</h3>
            <ul>
              <li>TU</li>
              <li>Keuangan</li>
              <li>Pesuruh</li>
            </ul>
          </div>
        </div>

        <div class="org-level">
          <div class="org-box">
            <h3>KESISWAAN</h3>
            <ul>
              <li>OSIS</li>
              <li>Paskibra</li>
              <li>Pramuka</li>
              <li>PMR</li>
              <li>KPLH GEMPAR</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  h2 {
    color: #1f2937;
    margin-bottom: 1.5rem;
  }

  .org-chart {
    text-align: center;
  }

  .org-level {
    margin-bottom: 1rem;
  }

  .org-box {
    display: inline-block;
    background: #f97316;
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    min-width: 250px;
  }

  .org-box.top {
    background: #ea580c;
    font-size: 1.2rem;
  }

  .org-box h3 {
    margin-bottom: 0.5rem;
  }

  .org-box ul {
    list-style: none;
    font-size: 0.85rem;
  }

  .org-box li {
    margin: 0.25rem 0;
  }
</style>
