---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sarana Prasarana">
  <div class="page-header">
    <h1>Sarana Prasarana</h1>
  </div>

  <div class="content">
    <section>
      <h2>Sarana dan Prasarana SMKN 1 Rongga</h2>
      <p>SMKN 1 Rongga memiliki berbagai fasilitas pendukung untuk proses pembelajaran yang optimal.</p>
    </section>

    <section>
      <h2>Ruang Kelas</h2>
      <ul>
        <li>Ruang teori yang nyaman dan memadai</li>
        <li>Ruang praktik sesuai kompetensi keahlian</li>
        <li>Ruang aula/pertemuan</li>
        <li>Ruang UKS</li>
        <li>Ruang BK (Bimbingan Konseling)</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas Labotatorium</h2>
      <ul>
        <li>Laboratorium Komputer</li>
        <li>Laboratorium Bahasa</li>
        <li>Laboratorium IPA (Fisika, Kimia, Biologi)</li>
        <li>LaboratoriumATPH</li>
        <li>Laboratorium TBSM</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas Olah Raga</h2>
      <ul>
        <li>Lapangan basket</li>
        <li>Lapangan voli</li>
        <li>Lapangan badminton</li>
        <li>Area pista</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas Pendukung</h2>
      <ul>
        <li>Perpustakaan</li>
        <li>Kantin</li>
        <li>Area parkir</li>
        <li>Mushola</li>
        <li>Toilet yang memadai</li>
        <li>Akses internet (Wifi)</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas Jurusan</h2>
      <h3>ATPH</h3>
      <ul>
        <li>Lahan praktik pertanian</li>
        <li>Rumah kaca (greenhouse)</li>
        <li>Kebra</li>
      </ul>
      <h3>RPL</h3>
      <ul>
        <li>Laboratorium komputer dengan koneksi internet</li>
        <li>Server room</li>
      </ul>
      <h3>TBSM</h3>
      <ul>
        <li>Bengkel praktik</li>
        <li>Alat-alat service</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2, h3 {
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
  }

  h2 {
    border-bottom: 2px solid #f97316;
  }

  h3 {
    margin-top: 1.5rem;
    color: #f97316;
  }

  ul {
    margin-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }
</style>
