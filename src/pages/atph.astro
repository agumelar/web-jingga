---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ATPH - Agribisnis Tanaman Pangan dan Hortikultura">
  <div class="page-header">
    <h1>Agribisnis Tanaman Pangan dan Hortikultura (ATPH)</h1>
  </div>

  <div class="content">
    <section>
      <h2>Tentang ATPH</h2>
      <p>ATPH merupakan kependekan dari <strong>Agribisnis Tanaman Pangan & Hortikultura</strong> yang merupakan salah satu program keahlian di SMKN 1 Rongga. Program ini mempelajari tentang budidaya tanaman pangan dan hortikultura secara modern dan berkelanjutan.</p>
    </section>

    <section>
      <h2>Kompetensi Keahlian</h2>
      <ul>
        <li>Budidaya Tanaman Pangan (Padi, Jagung, Kedelai, dll)</li>
        <li>Budidaya Hortikultura (Sayuran, Buah, Florikultura)</li>
        <li>Pengelolaan Pupuk dan Pestisida Organik</li>
        <li>Pengelolaan Pupuk dan Pestisida</li>
        <li>Pascapanen dan Pengolahan Hasil</li>
        <li>Kewirausahaan di Bidang Pertanian</li>
      </ul>
    </section>

    <section>
      <h2>Prospek Karir</h2>
      <p>Lulusan ATPH dapat bekerja di:</p>
      <ul>
        <li>Perusahaan pertanian modern</li>
        <li>Korporasi agribisnis</li>
        <li>Balai pertanian</li>
        <li>Wirausaha pertanian mandiri</li>
        <li>KUD dan kelompok tani</li>
        <li>Industri pangan dan sejenisnya</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas</h2>
      <ul>
        <li>Lahan praktik pertanian</li>
        <li>Rumah kaca (greenhouse)</li>
        <li>Laboratorium tanah dan tanaman</li>
        <li>Alat-alat pertanian modern</li>
        <li>Kebra</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #22c55e;
  }

  ul {
    margin-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }
</style>
