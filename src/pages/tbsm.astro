---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="TBSM - Teknik dan Bisnis Sepeda Motor">
  <div class="page-header">
    <h1>Teknik dan Bisnis Sepeda Motor (TBSM)</h1>
  </div>

  <div class="content">
    <section>
      <h2>Tentang TBSM</h2>
      <p><strong>Teknik dan Bisnis Sepeda Motor (TBSM)</strong> adalah bidang kompetensi teknologi yang membekali siswa dengan teknik-service dan manajemen bisnis di bidang Sepeda Motor. Siswa akan mempelajari perawatan dan perbaikan berbagai jenis sepeda motor.</p>
    </section>

    <section>
      <h2>Kompetensi Keahlian</h2>
      <ul>
        <li>Perawatan Berkala Sepeda Motor</li>
        <li>Perbaikan Mesin Sepeda Motor</li>
        <li>Perbaikan Sistem Kelistrikan</li>
        <li>Perbaikan Sistem Rem</li>
        <li>Perbaikan Sistem Suspension</li>
        <li>Perbaikan Transmisi</li>
        <li>Teknik Bisnis Service</li>
        <li>Manajemen Bengkel</li>
      </ul>
    </section>

    <section>
      <h2>Prospek Karir</h2>
      <p>Lulusan TBSM dapat bekerja di:</p>
      <ul>
        <li>Bengkel Resmi (AHASS, FCC, dll)</li>
        <li>Bengkel Umum</li>
        <li>Technician Toyota/Astra</li>
        <li>Wirausaha Bengkel Motor</li>
        <li>Sales Associate Spare Parts</li>
        <li>Quality Control di industri otomotif</li>
      </ul>
    </section>

    <section>
      <h2>Fasilitas Praktik</h2>
      <ul>
        <li>Bengkel praktik lengkap</li>
        <li>Alat-alat service standar Germania</li>
        <li>Mesin diesel dan bensin</li>
        <li>Stand praktik injection</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #ef4444;
  }

  ul {
    margin-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }
</style>
