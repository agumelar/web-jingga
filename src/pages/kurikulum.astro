---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kurikulum">
  <div class="page-header">
    <h1>Kurikulum</h1>
  </div>

  <div class="content">
    <section>
      <h2>Kurikulum SMKN 1 Rongga</h2>
      <p>SMKN 1 Rongga menerapkan kurikulum yang sesuai dengan standar nasional pendidikan dan tuntutan dunia kerja. Kurikulum kami dirancang untuk menghasilkan lulusan yang kompeten, kompetitif, dan berakhlakul karimah.</p>
    </section>

    <section>
      <h2>Struktur Kurikulum</h2>
      <table class="kurikulum-table">
        <thead>
          <tr>
            <th>Komponen</th>
            <th>Keterangan</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Muatan Nasional</td>
            <td>Pendidikan Agama, PPKn, Bahasa Indonesia, Matematika, IPA, IPS, Bahasa Inggris, Seni dan Budaya, PJOK</td>
          </tr>
          <tr>
            <td>Muatan Kewilayahan</td>
            <td>Sejarah Jawa Barat, Bahasa Sunda</td>
          </tr>
          <tr>
            <td>MuatanProduk Kreatif dan Kewirausahaan</td>
            <td>Kewirausahaan, Simulasi Digital, Produktif Jurusan</td>
          </tr>
          <tr>
            <td>Produktif Jurusan</td>
            <td>Mata pelajaran keahlian sesuai program keahlian (ATPH, RPL, TBSM)</td>
          </tr>
          <tr>
            <td>Praktik Kerja Industri (PRAKERIN)</td>
            <td>Praktik di dunia industri minimal 6 bulan</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Kebijakan Mutu</h2>
      <ul>
        <li>Peningkatan kualitas pembelajaran yang aktif, kreatif, dan inovatif</li>
        <li>Penguatan linkages dengan dunia industri</li>
        <li>Penerapan teknologi informasi dalam pembelajaran</li>
        <li>Pengembangan karakter peserta didik</li>
        <li>Evaluasi dan peningkatan berkelanjutan</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #f97316;
  }

  .kurikulum-table {
    width: 100%;
    border-collapse: collapse;
  }

  .kurikulum-table th, .kurikulum-table td {
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    text-align: left;
  }

  .kurikulum-table th {
    background: #f3f4f6;
  }

  ul {
    margin-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }
</style>
